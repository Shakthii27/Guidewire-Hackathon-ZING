<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zing Prototype</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #0f0f13;
    font-family: 'Space Grotesk', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
    padding: 40px 20px;
    gap: 32px;
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    color: #fff;
    letter-spacing: -0.5px;
  }
  .subtitle { font-size: 13px; color: #666; margin-top: 4px; }

  .nav {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .nav-btn {
    padding: 8px 16px;
    border-radius: 40px;
    border: 1.5px solid #333;
    background: transparent;
    color: #888;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .nav-btn.active {
    background: #FF5722;
    border-color: #FF5722;
    color: #fff;
  }
  .nav-btn:hover:not(.active) { border-color: #FF5722; color: #FF5722; }

  .phone-frame {
    width: 375px;
    height: 812px;
    background: #1a1a22;
    border-radius: 48px;
    border: 2px solid #2a2a35;
    overflow: hidden;
    position: relative;
    box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(255,255,255,0.04);
  }

  .screen { display: none; width: 100%; height: 100%; flex-direction: column; }
  .screen.active { display: flex; }

  /* ---- STATUS BAR ---- */
  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px 8px;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
  }
  .status-icons { display: flex; gap: 6px; align-items: center; font-size: 11px; }

  /* ---- SCREEN 1: ONBOARDING ---- */
  #s1 {
    background: linear-gradient(170deg, #0f0f1a 0%, #1a0a05 100%);
  }
  .s1-hero {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px 32px 0;
    text-align: center;
  }
  .s1-icon {
    width: 80px; height: 80px;
    background: #FF5722;
    border-radius: 28px;
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
    margin-bottom: 24px;
    box-shadow: 0 12px 40px rgba(255,87,34,0.4);
  }
  .s1-title {
    font-family: 'Syne', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .s1-title span { color: #FF5722; }
  .s1-desc { font-size: 14px; color: #888; line-height: 1.6; margin-bottom: 32px; }
  .s1-badges {
    display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;
    margin-bottom: 32px;
  }
  .badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    border: 1px solid;
  }
  .badge-heat { background: rgba(255,87,34,0.12); color: #FF7043; border-color: rgba(255,87,34,0.3); }
  .badge-aqi  { background: rgba(156,39,176,0.12); color: #CE93D8; border-color: rgba(156,39,176,0.3); }
  .badge-flood{ background: rgba(33,150,243,0.12); color: #90CAF9; border-color: rgba(33,150,243,0.3); }

  .s1-bottom { padding: 20px 24px 40px; }
  .btn-primary {
    width: 100%;
    padding: 16px;
    border-radius: 16px;
    border: none;
    background: #FF5722;
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(255,87,34,0.35);
  }
  .btn-secondary {
    width: 100%;
    padding: 14px;
    border-radius: 16px;
    border: 1.5px solid #2a2a35;
    background: transparent;
    color: #888;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    cursor: pointer;
    margin-top: 10px;
  }

  /* ---- SCREEN 2: DASHBOARD ---- */
  #s2 { background: #0f0f13; }
  .dash-header {
    padding: 8px 24px 16px;
    flex-shrink: 0;
  }
  .dash-greeting { font-size: 13px; color: #666; margin-bottom: 2px; }
  .dash-name { font-family: 'Syne', sans-serif; font-size: 22px; color: #fff; }
  .dash-name span { color: #FF5722; }

  .shield-card {
    margin: 0 16px 16px;
    border-radius: 24px;
    background: linear-gradient(135deg, #FF5722 0%, #BF360C 100%);
    padding: 20px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .shield-card::after {
    content: '';
    position: absolute;
    right: -20px; top: -20px;
    width: 130px; height: 130px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
  }
  .shield-tier { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.7); letter-spacing: 1px; text-transform: uppercase; }
  .shield-status { font-family: 'Syne', sans-serif; font-size: 26px; color: #fff; margin: 4px 0; }
  .shield-sub { font-size: 12px; color: rgba(255,255,255,0.6); }
  .shield-row {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-top: 16px;
  }
  .shield-payout { }
  .shield-payout-label { font-size: 11px; color: rgba(255,255,255,0.6); }
  .shield-payout-val { font-family: 'Syne', sans-serif; font-size: 22px; color: #fff; }
  .shield-badge {
    background: rgba(255,255,255,0.2);
    padding: 6px 12px; border-radius: 20px;
    font-size: 11px; color: #fff; font-weight: 600;
  }

  .section-title { font-size: 13px; font-weight: 600; color: #666; letter-spacing: 0.5px; padding: 0 24px; margin-bottom: 10px; text-transform: uppercase; }

  .metrics-row { display: flex; gap: 10px; padding: 0 16px; margin-bottom: 16px; flex-shrink: 0; }
  .metric-card {
    flex: 1;
    background: #1a1a22;
    border-radius: 16px;
    padding: 14px;
    border: 1px solid #252530;
  }
  .metric-icon { font-size: 18px; margin-bottom: 6px; }
  .metric-val { font-family: 'Syne', sans-serif; font-size: 20px; color: #fff; }
  .metric-label { font-size: 11px; color: #555; margin-top: 2px; }
  .metric-val.hot { color: #FF5722; }
  .metric-val.bad { color: #CE93D8; }
  .metric-val.ok { color: #81C784; }

  .alert-banner {
    margin: 0 16px 16px;
    background: rgba(255,87,34,0.1);
    border: 1px solid rgba(255,87,34,0.25);
    border-radius: 16px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .alert-dot {
    width: 10px; height: 10px; border-radius: 50%; background: #FF5722;
    flex-shrink: 0;
    box-shadow: 0 0 0 4px rgba(255,87,34,0.2);
    animation: pulse 1.5s infinite;
  }
  @keyframes pulse {
    0%,100% { box-shadow: 0 0 0 4px rgba(255,87,34,0.2); }
    50% { box-shadow: 0 0 0 8px rgba(255,87,34,0.05); }
  }
  .alert-text { font-size: 13px; color: #FF7043; line-height: 1.4; }
  .alert-text strong { color: #FF5722; }

  .bottom-nav {
    margin-top: auto;
    display: flex;
    background: #141418;
    border-top: 1px solid #1f1f28;
    padding: 12px 0 24px;
    flex-shrink: 0;
  }
  .nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .nav-icon { font-size: 18px; }
  .nav-label { font-size: 10px; color: #555; }
  .nav-item.active .nav-label { color: #FF5722; }

  /* ---- SCREEN 3: ALERT / TRIGGER ---- */
  #s3 { background: #0f0f13; }
  .trigger-top {
    padding: 8px 24px 20px;
    flex-shrink: 0;
  }
  .back-btn { font-size: 13px; color: #FF5722; margin-bottom: 12px; display: block; }
  .trigger-title { font-family: 'Syne', sans-serif; font-size: 24px; color: #fff; line-height: 1.2; }

  .trigger-hero {
    margin: 0 16px 16px;
    background: linear-gradient(135deg, #1a0800, #2a0f0f);
    border: 1px solid rgba(255,87,34,0.25);
    border-radius: 24px;
    padding: 24px;
    text-align: center;
    flex-shrink: 0;
  }
  .temp-display {
    font-family: 'Syne', sans-serif;
    font-size: 64px;
    color: #FF5722;
    line-height: 1;
    margin: 8px 0;
  }
  .temp-label { font-size: 12px; color: #666; letter-spacing: 1px; text-transform: uppercase; }
  .temp-sub { font-size: 13px; color: #FF7043; margin-top: 6px; }
  .wbgt-bar-wrap { margin: 16px 0 0; }
  .wbgt-label { display: flex; justify-content: space-between; font-size: 11px; color: #555; margin-bottom: 6px; }
  .wbgt-bar { height: 8px; border-radius: 4px; background: #1f1f28; overflow: hidden; }
  .wbgt-fill { height: 100%; width: 78%; background: linear-gradient(90deg, #FF9800, #FF5722, #D32F2F); border-radius: 4px; }
  .danger-line { position: relative; }

  .checks-list { padding: 0 16px; flex: 1; overflow-y: auto; }
  .check-item {
    display: flex; align-items: center; gap: 14px;
    background: #1a1a22;
    border-radius: 14px;
    padding: 14px;
    margin-bottom: 10px;
    border: 1px solid #252530;
  }
  .check-icon {
    width: 40px; height: 40px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .check-icon.pass { background: rgba(76,175,80,0.12); }
  .check-icon.fail { background: rgba(244,67,54,0.12); }
  .check-icon.warn { background: rgba(255,152,0,0.12); }
  .check-text { flex: 1; }
  .check-name { font-size: 13px; color: #ccc; font-weight: 600; }
  .check-val  { font-size: 12px; color: #555; margin-top: 2px; }
  .check-status { font-size: 11px; font-weight: 700; }
  .check-status.pass { color: #81C784; }
  .check-status.fail { color: #EF9A9A; }
  .check-status.warn { color: #FFB74D; }

  .payout-trigger-btn {
    margin: 0 16px 16px;
    padding: 18px;
    border-radius: 20px;
    border: none;
    background: #FF5722;
    color: #fff;
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    flex-shrink: 0;
    box-shadow: 0 8px 32px rgba(255,87,34,0.4);
  }

  /* ---- SCREEN 4: PAYOUT ---- */
  #s4 { background: #0f0f13; }
  .payout-anim-wrap {
    flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center;
    padding: 24px 24px 16px;
    text-align: center;
  }
  .check-circle {
    width: 80px; height: 80px; border-radius: 50%;
    background: rgba(76,175,80,0.15);
    border: 2px solid #4CAF50;
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
    margin-bottom: 16px;
  }
  .payout-head { font-family: 'Syne', sans-serif; font-size: 28px; color: #fff; }
  .payout-amount { font-family: 'Syne', sans-serif; font-size: 48px; color: #81C784; line-height: 1.1; }
  .payout-sub { font-size: 13px; color: #555; margin-top: 4px; }

  .payout-breakdown {
    margin: 0 16px 16px;
    background: #1a1a22;
    border-radius: 20px;
    padding: 16px;
    border: 1px solid #252530;
    flex-shrink: 0;
  }
  .breakdown-row {
    display: flex; justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid #252530;
    font-size: 13px;
  }
  .breakdown-row:last-child { border-bottom: none; }
  .breakdown-key { color: #666; }
  .breakdown-val { color: #ccc; font-weight: 600; }
  .breakdown-val.green { color: #81C784; }

  .fraud-pass {
    margin: 0 16px 16px;
    background: rgba(76,175,80,0.08);
    border: 1px solid rgba(76,175,80,0.2);
    border-radius: 16px;
    padding: 14px 16px;
    flex-shrink: 0;
  }
  .fraud-pass-title { font-size: 12px; color: #81C784; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 8px; text-transform: uppercase; }
  .fraud-checks { display: flex; flex-direction: column; gap: 6px; }
  .fraud-row { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #555; }
  .fraud-tick { color: #81C784; font-weight: 700; }

  .upi-btn {
    margin: 0 16px;
    padding: 16px;
    border-radius: 16px;
    border: none;
    background: #1a73e8;
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; font-weight: 600;
    flex-shrink: 0;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }

  /* ---- SCREEN 5: FRAUD / RISK ---- */
  #s5 { background: #0f0f13; }
  .fraud-header { padding: 8px 24px 16px; flex-shrink: 0; }
  .fraud-title { font-family: 'Syne', sans-serif; font-size: 22px; color: #fff; }

  .risk-score-card {
    margin: 0 16px 14px;
    border-radius: 20px;
    background: #1a1a22;
    border: 1px solid #252530;
    padding: 18px;
    display: flex; align-items: center; gap: 16px;
    flex-shrink: 0;
  }
  .risk-ring {
    width: 64px; height: 64px; flex-shrink: 0;
    position: relative;
  }
  .risk-ring svg { position: absolute; top: 0; left: 0; }
  .risk-num {
    position: absolute;
    inset: 0; display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-size: 18px; color: #81C784;
  }
  .risk-info { flex: 1; }
  .risk-score-label { font-size: 11px; color: #555; text-transform: uppercase; letter-spacing: 0.5px; }
  .risk-score-val { font-family: 'Syne', sans-serif; font-size: 20px; color: #81C784; }
  .risk-tier { font-size: 12px; color: #555; }

  .fraud-checks-list { padding: 0 16px; flex: 1; overflow-y: auto; }
  .fraud-check-card {
    background: #1a1a22;
    border-radius: 16px;
    border: 1px solid #252530;
    padding: 14px;
    margin-bottom: 10px;
  }
  .fcc-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
  .fcc-name { font-size: 13px; color: #ccc; font-weight: 600; }
  .fcc-status-pill {
    padding: 3px 10px; border-radius: 20px; font-size: 10px; font-weight: 700;
  }
  .pill-pass { background: rgba(76,175,80,0.15); color: #81C784; }
  .pill-fail { background: rgba(244,67,54,0.15); color: #EF9A9A; }
  .pill-watch { background: rgba(255,152,0,0.15); color: #FFB74D; }
  .fcc-desc { font-size: 12px; color: #555; line-height: 1.5; }
  .fcc-data { font-size: 11px; color: #FF7043; margin-top: 4px; font-weight: 600; }
  .fcc-data.ok { color: #81C784; }

  .bottom-note {
    margin: 0 16px 16px;
    padding: 12px 16px;
    background: rgba(255,87,34,0.08);
    border: 1px solid rgba(255,87,34,0.15);
    border-radius: 12px;
    font-size: 12px;
    color: #FF7043;
    line-height: 1.5;
    flex-shrink: 0;
  }

  /* Scrollbar hide */
  ::-webkit-scrollbar { width: 0; }
</style>
</head>
<body>

<div style="text-align:center">
  <h1>Zing</h1>
  <p class="subtitle">App Prototype — 5 Screens · Click to navigate</p>
</div>

<div class="nav">
  <button class="nav-btn active" onclick="show(1)">01 · Onboarding</button>
  <button class="nav-btn" onclick="show(2)">02 · Dashboard</button>
  <button class="nav-btn" onclick="show(3)">03 · Alert Trigger</button>
  <button class="nav-btn" onclick="show(4)">04 · Payout</button>
  <button class="nav-btn" onclick="show(5)">05 · Zing Shield</button>
</div>

<div class="phone-frame">

  <!-- SCREEN 1: ONBOARDING -->
  <div id="s1" class="screen active">
    <div class="status-bar">
      <span>9:41</span>
      <div class="status-icons"><span>●●●</span><span>WiFi</span><span>🔋</span></div>
    </div>
    <div class="s1-hero">
      <div class="s1-icon">🛡</div>
      <div class="s1-title">Zing</div>
      <p class="s1-desc">Parametric micro-insurance for India's delivery workforce. We protect your income — automatically.</p>
      <div class="s1-badges">
        <span class="badge badge-heat">🌡 Heatwave</span>
        <span class="badge badge-aqi">💨 Air Quality</span>
        <span class="badge badge-flood">🌧 Flash Flood</span>
      </div>
    </div>
    <div class="s1-bottom">
      <button class="btn-primary">Link Zomato ID &amp; Get Started</button>
      <button class="btn-secondary">I already have an account</button>
      <p style="font-size:11px;color:#444;text-align:center;margin-top:14px;">By continuing you agree to our Terms &amp; Privacy Policy</p>
    </div>
  </div>

  <!-- SCREEN 2: DASHBOARD -->
  <div id="s2" class="screen">
    <div class="status-bar">
      <span>9:41</span>
      <div class="status-icons"><span>●●●</span><span>WiFi</span><span>🔋</span></div>
    </div>
    <div class="dash-header">
      <div class="dash-greeting">Good morning,</div>
      <div class="dash-name">Ravi <span>Sharma</span> 👋</div>
    </div>
    <div class="shield-card">
      <div class="shield-tier">Gold Tier · Zomato Partner</div>
      <div class="shield-status">Zing Active</div>
      <div class="shield-sub">Week of May 19 – 25, 2026</div>
      <div class="shield-row">
        <div class="shield-payout">
          <div class="shield-payout-label">This week's coverage</div>
          <div class="shield-payout-val">₹1,200</div>
        </div>
        <div class="shield-badge">₹20 premium paid ✓</div>
      </div>
    </div>
    <div class="metrics-row">
      <div class="metric-card">
        <div class="metric-icon">🌡</div>
        <div class="metric-val hot">44°C</div>
        <div class="metric-label">Heat Index</div>
      </div>
      <div class="metric-card">
        <div class="metric-icon">💨</div>
        <div class="metric-val bad">382</div>
        <div class="metric-label">AQI</div>
      </div>
      <div class="metric-card">
        <div class="metric-icon">🌧</div>
        <div class="metric-val ok">12mm</div>
        <div class="metric-label">Rainfall</div>
      </div>
    </div>
    <div class="alert-banner">
      <div class="alert-dot"></div>
      <div class="alert-text"><strong>Heat Advisory — Dwarka Sector 10</strong><br>WBGT approaching danger zone. Monitoring active.</div>
    </div>
    <div class="bottom-nav">
      <div class="nav-item active"><span class="nav-icon">🏠</span><span class="nav-label" style="color:#FF5722">Home</span></div>
      <div class="nav-item"><span class="nav-icon">📊</span><span class="nav-label">History</span></div>
      <div class="nav-item"><span class="nav-icon">💰</span><span class="nav-label">Payouts</span></div>
      <div class="nav-item"><span class="nav-icon">👤</span><span class="nav-label">Profile</span></div>
    </div>
  </div>

  <!-- SCREEN 3: ALERT TRIGGER -->
  <div id="s3" class="screen">
    <div class="status-bar">
      <span>9:41</span>
      <div class="status-icons"><span>●●●</span><span>WiFi</span><span>🔋</span></div>
    </div>
    <div class="trigger-top">
      <span class="back-btn">← Back</span>
      <div class="trigger-title">Heatwave<br>Disruption Alert</div>
    </div>
    <div class="trigger-hero">
      <div class="temp-label">Wet Bulb Globe Temperature · WBGT</div>
      <div class="temp-display">36.2°</div>
      <div class="temp-sub">⚠ Danger threshold crossed (35°C) · 3h 10min</div>
      <div class="wbgt-bar-wrap">
        <div class="wbgt-label"><span>Safe</span><span>Caution</span><span>Danger</span></div>
        <div class="wbgt-bar"><div class="wbgt-fill"></div></div>
      </div>
    </div>
    <div class="checks-list">
      <div class="section-title" style="margin-top:0">Parametric Checks</div>
      <div class="check-item">
        <div class="check-icon pass">🌡</div>
        <div class="check-text">
          <div class="check-name">Thermal Stress</div>
          <div class="check-val">WBGT = 36.2°C &gt; 35°C for 3h+</div>
        </div>
        <span class="check-status pass">✓ MET</span>
      </div>
      <div class="check-item">
        <div class="check-icon pass">📍</div>
        <div class="check-text">
          <div class="check-name">Zone Match</div>
          <div class="check-val">Dwarka Sector 10 · Pin 110075</div>
        </div>
        <span class="check-status pass">✓ MET</span>
      </div>
      <div class="check-item">
        <div class="check-icon warn">📱</div>
        <div class="check-text">
          <div class="check-name">Activity Status</div>
          <div class="check-val">Rider logged off Zomato 3h ago</div>
        </div>
        <span class="check-status pass">✓ MET</span>
